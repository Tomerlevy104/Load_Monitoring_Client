<?xml version="1.0" encoding="utf-8"?>
<!-- קובץ Drawable המגדיר את הרקע של ה-Header עם גרדיאנט ופינות מעוגלות למטה -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- הגדרת הגרדיאנט: כחול כהה עמוק לכחול מעט בהיר יותר -->
    <gradient
        android:angle="270"
        android:startColor="#1A3A6A"
        android:endColor="#0A192F"
        android:type="linear" />

    <!-- עיגול הפינות התחתונות בלבד כפי שמופיע בעיצוב המודרני -->
    <corners
        android:bottomLeftRadius="48dp"
        android:bottomRightRadius="48dp" />

</shape>