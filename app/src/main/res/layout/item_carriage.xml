<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_marginEnd="16dp"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingBottom="8dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground">

    <FrameLayout
            android:layout_width="100dp"
            android:layout_height="40dp">

        <!-- גוף הקרון -->
        <View
                android:layout_width="match_parent"
                android:layout_height="30dp"
                android:layout_gravity="top"
                android:background="@drawable/carriage_body_bg" />

        <!-- דלת אדומה במרכז (כמו ב-Double Deck) -->
        <View
                android:layout_width="12dp"
                android:layout_height="30dp"
                android:layout_gravity="center_horizontal|top"
                android:background="#4d545e" />

        <!-- מספר הקרון -->
        <TextView
                android:id="@+id/tvCarriageNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal|top"
                android:layout_marginTop="6dp"
                android:text="1"
                android:textColor="@android:color/white"
                android:textSize="9sp"
                android:textStyle="bold" />

        <!-- גלגלים -->
        <View
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_gravity="bottom|start"
                android:layout_marginStart="20dp"
                android:background="@drawable/dot_slate_light" />

        <View
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_gravity="bottom|end"
                android:layout_marginEnd="20dp"
                android:background="@drawable/dot_slate_light" />

    </FrameLayout>

    <!-- פס חיווי עומס -->
    <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/imgCarriageOccupancy"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_marginBottom="2dp"
            android:scaleType="fitCenter"
            android:contentDescription="@string/carriage_occupancy"
            android:src="@drawable/ic_low_load"
            tools:src="@drawable/ic_medium_load"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />
    />

</LinearLayout>