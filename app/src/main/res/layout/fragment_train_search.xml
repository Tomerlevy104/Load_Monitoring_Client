<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        android:fitsSystemWindows="false"
        tools:context=".MainActivity"
        android:layoutDirection="rtl">

    <View
            android:id="@+id/headerBackground"
            android:layout_width="match_parent"
            android:layout_height="280dp"
            android:background="@drawable/header_gradient_bg"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    <TextView
            android:id="@+id/headerTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="64dp"
            android:layout_marginStart="24dp"
            android:text="לאן נוסעים היום?"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    <TextView
            android:id="@+id/headerSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="תכנון מסלול פשוט ומהיר"
            android:textColor="#B3FFFFFF"
            android:textSize="16sp"
            app:layout_constraintStart_toStartOf="@+id/headerTitle"
            app:layout_constraintTop_toBottomOf="@+id/headerTitle" />

    <com.google.android.material.card.MaterialCardView
            android:id="@+id/searchCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="16dp"
            android:layout_marginTop="60dp"
            app:cardBackgroundColor="@android:color/white"
            app:strokeColor="#EDF2F7"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/headerSubtitle">

        <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="24dp">

            <!-- שדה מוצא (From) -->
            <LinearLayout
                    android:id="@+id/fromContainer"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:background="@drawable/input_field_bg"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:layoutDirection="rtl"
                    app:layout_constraintTop_toTopOf="parent">

                <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_location_start"
                        app:tint="#3B82F6" />

                <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="נקודת מוצא"
                            android:textColor="#94A3B8"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/etOrigin"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@null"
                            android:hint="מאיפה?"
                            android:textColorHint="#94A3B8"
                            android:textColor="#1E293B"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:inputType="text"/>
                </LinearLayout>
            </LinearLayout>

            <!-- שדה יעד (To) -->
            <LinearLayout
                    android:id="@+id/toContainer"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/input_field_bg"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:layoutDirection="rtl"
                    app:layout_constraintTop_toBottomOf="@id/fromContainer">

                <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_location_end"
                        app:tint="#0EA5E9" />

                <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="יעד נסיעה"
                            android:textColor="#94A3B8"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/etDestination"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@null"
                            android:hint="לאן?"
                            android:textColorHint="#94A3B8"
                            android:textColor="#1E293B"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:inputType="text"/>
                </LinearLayout>
            </LinearLayout>

            <!-- כפתור החלפה (Swap Button) -->
            <!-- הוא מקושר ב-Constraint לשני השדות כדי לצוף ביניהם -->
            <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSwap"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="2dp"
                    android:backgroundTint="@android:color/white"
                    app:strokeColor="#E2E8F0"
                    app:strokeWidth="1dp"
                    android:insetLeft="0dp"
                    android:insetTop="0dp"
                    android:insetRight="0dp"
                    android:insetBottom="0dp"
                    android:padding="0dp"
                    app:cornerRadius="22dp"
                    app:elevation="8dp"
                    app:icon="@drawable/ic_swap"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:iconTint="#3B82F6"
                    app:layout_constraintTop_toBottomOf="@id/fromContainer"
                    app:layout_constraintBottom_toTopOf="@id/toContainer"
                    app:layout_constraintEnd_toEndOf="parent" />

            <!-- שורת תאריך ושעה -->
            <LinearLayout
                    android:id="@+id/dateTimeRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal"
                    android:layoutDirection="rtl"
                    app:layout_constraintTop_toBottomOf="@id/toContainer">

                <LinearLayout
                        android:id="@+id/dateContainer"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/input_field_bg"
                        android:gravity="center_vertical"
                        android:padding="14dp">

                    <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_calendar"
                            app:tint="#94A3B8" />

                    <TextView
                            android:id="@+id/tvSelectedDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="היום, 24 אוק׳"
                            android:textColor="#475569"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                </LinearLayout>

                <View
                        android:layout_width="12dp"
                        android:layout_height="match_parent" />

                <LinearLayout
                        android:id="@+id/timePickerContainer"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/input_field_bg"
                        android:gravity="center_vertical"
                        android:padding="14dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                    <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_clock"
                            app:tint="#94A3B8" />

                    <TextView
                            android:id="@+id/tvSelectedTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="08:00"
                            android:textColor="#475569"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- כפתור חיפוש רכבות -->
            <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSearch"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="20dp"
                    app:backgroundTint="@null"
                    android:background="@drawable/btn_search_gradient"
                    android:text="חיפוש רכבות"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="20dp"
                    app:layout_constraintTop_toBottomOf="@id/dateTimeRow" />

        </androidx.constraintlayout.widget.ConstraintLayout>


    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>